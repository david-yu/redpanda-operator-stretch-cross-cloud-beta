        "overrides": [
          { "matcher": { "id": "byRegexp", "options": "redpanda-rp-aws-.*" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] },
          { "matcher": { "id": "byRegexp", "options": "redpanda-rp-gcp-.*" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }] },
          { "matcher": { "id": "byRegexp", "options": "redpanda-rp-azure-.*" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "purple" } }] }
        ]
