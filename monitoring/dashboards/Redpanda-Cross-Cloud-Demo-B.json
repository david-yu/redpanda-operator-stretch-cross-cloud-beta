        { "datasource": { "type": "prometheus", "uid": "PF2AF1CE8C60FA39E" }, "expr": "sum by (pod) (redpanda_cluster_partition_moving_to_node)", "legendFormat": "{{pod}}", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "P798A6BC1AFC6F104" }, "expr": "sum by (pod) (redpanda_cluster_partition_moving_to_node)", "legendFormat": "{{pod}}", "refId": "C" }
