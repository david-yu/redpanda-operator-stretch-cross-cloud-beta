      "targets": [
        {
          "expr": "max(redpanda_storage_disk_free_space_alert)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "max": 2,
          "mappings": [
            {
              "type": "value",
