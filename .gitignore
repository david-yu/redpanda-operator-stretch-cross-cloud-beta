# Never commit licenses, kubeconfigs, or rendered values with real endpoints.
*.license
*.key
kubeconfig*
values-rp-aws.yaml
values-rp-gcp.yaml
values-rp-azure.yaml
clustermesh-apiserver-ca.crt
*.kubeconfig

# Local-only Helm value overrides for the demo addons (Console / Grafana).
# install-monitoring.sh prints the auto-generated Grafana admin password
# rather than writing it anywhere — but if you choose to pin it for
# reproducibility, drop it in *.local.yaml and never check it in.
*.local.yaml
console-creds.txt
grafana-creds.txt

# Local logs / scratch
*.log
*.bak
.DS_Store

# Terraform local state and provider cache
.terraform/
*.tfstate
*.tfstate.*
.terraform.lock.hcl
*.tfvars
!*.tfvars.example
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
